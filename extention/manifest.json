{
  "author": "Khaled Saleh",
  "background": {
    "scripts": [
      "requestInterceptor.js"  
    ]
  },
  "description": "spicial For letswatch website",
  "manifest_version": 2,
  "name": "HTTP-TRACKER",
  "permissions": [
    "storage",
    "webRequest",
    "<all_urls>",
    "webRequestBlocking",
    "tabs",
    "cookies",
    "activeTab"
  ],
  "version": "2.2.6",
  "browser_action": {
    "browser_style": true
    },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
